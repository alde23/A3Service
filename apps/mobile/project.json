{
  "name": "mobile",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/mobile/src",
  "projectType": "application",
  "targets": {
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx expo start --port 8081",
        "cwd": "apps/mobile",
        "env": {
          "EXPO_ROUTER_APP_ROOT": "src/app"
        }
      }
    }
  }
}